<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE artifacts>

<artifacts>
	<artifact name="br.com.concepting.framework.model.util.ModelUtil.getResourcesIdByModel(#{clazz})">
		list.label=List
		list.tooltip=
		input.label=Add / Edit an item
		input.tooltip=
		inputFieldset.label=Form fields
		inputFieldset.tooltip=

		<set var="hasSearchProperty" value="#{declaration}.hasPropertyInfo('search')"/>
		<if expr="@{hasSearchProperty}">
			<set var="searchPropertyInfo" value="#{declaration}.getPropertyInfo('search')"/>
			<set var="searchPropertyClass" value="@{searchPropertyInfo.clazz}"/>
			<set var="searchPropertyModelInfo" value="br.com.concepting.framework.model.util.ModelUtil.getInfo(@{searchPropertyClass})"/>
			<set var="searchPropertyClassName" value="@{searchPropertyClass.name}"/>
			<set var="searchPropertyName" value="@{searchPropertyClass.simpleName}"/>
			<set var="searchPropertySuffix" value="@{searchPropertyName}.substring(1)"/>
			<set var="searchPropertySuffix" value="br.com.concepting.framework.util.StringUtil.replaceAll(@{searchPropertySuffix}, 'Model', '')"/>
			<set var="searchPropertyPrefix" value="@{searchPropertyName}.substring(0, 1)"/>
			<set var="searchPropertyPrefix" value="@{searchPropertyPrefix}.toLowerCase()"/>
			<set var="searchPropertyPrefix" value="@{searchPropertyPrefix}.concat(@{searchPropertySuffix})"/>
		</if>
		<set var="hasInputProperty" value="#{declaration}.hasPropertyInfo('input')"/>
		<if expr="@{hasInputProperty}">
			<set var="inputPropertyInfo" value="#{declaration}.getPropertyInfo('input')"/>
			<set var="inputPropertyClass" value="@{inputPropertyInfo.clazz}"/>
			<set var="inputPropertyModelInfo" value="br.com.concepting.framework.model.util.ModelUtil.getInfo(@{inputPropertyClass})"/>
			<set var="inputPropertyClassName" value="@{inputPropertyClass.name}"/>
			<set var="inputPropertyName" value="@{inputPropertyClass.simpleName}"/>
			<set var="inputPropertySuffix" value="@{inputPropertyName}.substring(1)"/>
			<set var="inputPropertySuffix" value="br.com.concepting.framework.util.StringUtil.replaceAll(@{inputPropertySuffix}, 'Model', '')"/>
			<set var="inputPropertyPrefix" value="@{inputPropertyName}.substring(0, 1)"/>
			<set var="inputPropertyPrefix" value="@{inputPropertyPrefix}.toLowerCase()"/>
			<set var="inputPropertyPrefix" value="@{inputPropertyPrefix}.concat(@{inputPropertySuffix})"/>
		</if>
		<if expr="@{searchPropertyModelInfo} != null and @{searchPropertyClassName} != @{inputPropertyClassName}">
			<iterate var="propertyInfo" values="@{searchPropertyModelInfo.searchPropertiesInfo}">
				<if expr="(@{propertyInfo.mappedPropertyId} != null and @{propertyInfo.mappedPropertyId} != '') or @{propertyInfo.relationType} != 'NONE'">
		            <set var="propertyId" value="@{searchPropertyPrefix}.concat('.').concat(@{propertyInfo.id})"/>
		            <set var="propertyLabel" value="br.com.concepting.framework.util.StringUtil.capitalize(@{propertyInfo.id})"/>
		            @{propertyId}.label=@{propertyLabel}
		            @{propertyId}.tooltip=
				</if>
			</iterate>
		</if>
		<iterate var="propertyInfo" values="@{inputPropertyModelInfo.propertiesInfo}">
			<if expr="(@{propertyInfo.mappedPropertyId} != null and @{propertyInfo.mappedPropertyId} != '') or @{propertyInfo.relationType} != 'NONE'">
	            <set var="propertyId" value="@{inputPropertyPrefix}.concat('.').concat(@{propertyInfo.id})"/>
	            <set var="propertyLabel" value="br.com.concepting.framework.util.StringUtil.capitalize(@{propertyInfo.id})"/>
	            @{propertyId}.label=@{propertyLabel}
	            @{propertyId}.tooltip=
			</if>
		</iterate>
	</artifact>
</artifacts>